# Contact form email (where form submissions are sent)
CONTACT_EMAIL=instanthelp24hr@gmail.com

# SMTP configuration (optional — for sending emails via API route)
# If not set, form data is logged and you rely on Netlify Forms instead
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Site URL
NEXT_PUBLIC_SITE_URL=https://nursingschooltutors.com

# WhatsApp number (without +)
NEXT_PUBLIC_WA_NUMBER=17654709090
